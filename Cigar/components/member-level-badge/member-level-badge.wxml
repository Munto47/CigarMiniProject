<view class="mlb-wrap mlb-wrap--{{size}}">
  <!-- 充值等级：等级图标（已内置等级数字，不需要额外文字） -->
  <view wx:if="{{type === 'recharge'}}" class="mlb-badge mlb-badge--recharge mlb-badge--{{size}}">
    <image class="mlb-icon-img mlb-icon-img--{{size}}" src="{{levelImage}}" mode="aspectFit" lazy-load />
  </view>

  <!-- 消费等级：雪茄图标 + 等级数字 -->
  <view wx:else class="mlb-badge mlb-badge--cigar mlb-badge--{{size}}">
    <image class="mlb-icon-img mlb-icon-img--{{size}}" src="{{cigarImage}}" mode="aspectFit" lazy-load />
    <text class="mlb-num mlb-num--{{size}}">{{levelText}}</text>
  </view>
</view>
