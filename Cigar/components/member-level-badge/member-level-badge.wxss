/* ═══════════════════════════════════════════
   member-level-badge — 图片图标版
   充值等级使用 level 图片（已含等级数字）
   消费等级使用 cigar 图片 + 纯数字
   ═══════════════════════════════════════════ */

/* ── 外层包装：图标 + 数字横向排列 ── */
.mlb-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
}
.mlb-wrap--sm  { gap: 6rpx; }
.mlb-wrap--md  { gap: 10rpx; }
.mlb-wrap--lg  { gap: 14rpx; }

/* ── 徽章主体 ── */
.mlb-badge {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
}
.mlb-badge--sm  { gap: 6rpx; }
.mlb-badge--md  { gap: 10rpx; }
.mlb-badge--lg  { gap: 14rpx; }

/* ── 图标图片 ── */
.mlb-icon-img {
  flex-shrink: 0;
}
.mlb-icon-img--sm  { width: 44rpx; height: 44rpx; }
.mlb-icon-img--md  { width: 64rpx; height: 64rpx; }
.mlb-icon-img--lg  { width: 88rpx; height: 88rpx; }

/* ── 等级数字（仅消费等级使用） ── */
.mlb-num {
  font-weight: 800;
  color: var(--color-gold-light);
  line-height: 1;
  flex-shrink: 0;
}
.mlb-num--sm { font-size: 22rpx; }
.mlb-num--md { font-size: 30rpx; }
.mlb-num--lg { font-size: 38rpx; }
