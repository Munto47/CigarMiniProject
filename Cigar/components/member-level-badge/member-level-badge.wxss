/* ═══════════════════════════════════════════
   member-level-badge — 对称结构版
   VIP 与 Cigar 使用完全相同的 [图标盒 + 数字] 布局
   图标盒等高 → 数字自然对齐在同一基线
   ═══════════════════════════════════════════ */

/* ── 外层包装：图标 + 数字横向排列 ── */
.mlb-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
}
.mlb-wrap--sm  { gap: 6rpx; }
.mlb-wrap--md  { gap: 10rpx; }
.mlb-wrap--lg  { gap: 14rpx; }

/* ── 徽章主体：图标盒 + 数字 ── */
.mlb-badge {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
}
/* 与 wrap 共用 gap，确保两类型内部间距一致 */
.mlb-badge--sm  { gap: 6rpx; }
.mlb-badge--md  { gap: 10rpx; }
.mlb-badge--lg  { gap: 14rpx; }

/* ════════════ 图标盒（两类型等高） ════════════ */

.mlb-icon-box {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.mlb-icon-box--sm  { width: 44rpx; height: 44rpx; }
.mlb-icon-box--md  { width: 64rpx; height: 64rpx; }
.mlb-icon-box--lg  { width: 88rpx; height: 88rpx; }

/* ── 公共辉光 ── */
.mlb-icon-glow {
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  background: radial-gradient(circle,
    rgba(232,201,122,0.15) 0%,
    rgba(201,168,76,0.04) 60%,
    transparent 100%
  );
  pointer-events: none;
  z-index: 0;
}

/* ════════════ VIP 菱形图标 ════════════ */

.mlb-vip-diamond {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 外层菱形 — 描边光环 */
.mlb-vip-diamond__outer {
  position: absolute;
  top: 50%;
  left: 50%;
  background: linear-gradient(135deg,
    rgba(232,201,122,0.3) 0%,
    rgba(201,168,76,0.12) 50%,
    rgba(122,100,48,0.2) 100%
  );
  border: 2rpx solid rgba(232,201,122,0.5);
  transform: translate(-50%, -50%) rotate(45deg);
  border-radius: 5rpx;
  box-shadow: 0 0 14rpx rgba(201,168,76,0.25);
}

/* 内层菱形 — 实心金色 */
.mlb-vip-diamond__inner {
  position: relative;
  z-index: 2;
  background: linear-gradient(135deg,
    #E8C97A 0%,
    #D4B55A 30%,
    #C9A84C 60%,
    #7A6430 100%
  );
  transform: rotate(45deg);
  border-radius: 3rpx;
  box-shadow:
    inset 0 1rpx 2rpx rgba(255,255,255,0.3),
    0 2rpx 6rpx rgba(0,0,0,0.4);
}

/* sm */
.mlb-icon-box--sm .mlb-vip-diamond__outer {
  width: 32rpx; height: 32rpx;
}
.mlb-icon-box--sm .mlb-vip-diamond__inner {
  width: 20rpx; height: 20rpx;
}

/* md */
.mlb-icon-box--md .mlb-vip-diamond__outer {
  width: 46rpx; height: 46rpx;
}
.mlb-icon-box--md .mlb-vip-diamond__inner {
  width: 30rpx; height: 30rpx;
}

/* lg */
.mlb-icon-box--lg .mlb-vip-diamond__outer {
  width: 64rpx; height: 64rpx;
}
.mlb-icon-box--lg .mlb-vip-diamond__inner {
  width: 40rpx; height: 40rpx;
}

/* ════════════ 雪茄图标 ════════════ */

.mlb-cigar-icon {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
}

/* 烟缕 */
.mlb-cigar-smoke {
  position: absolute;
  border-radius: 2rpx;
  background: rgba(201,168,76,0.18);
  pointer-events: none;
  animation: smokeDrift 2.2s ease-in-out infinite;
}
.mlb-cigar-smoke--1 { animation-delay: 0s; }
.mlb-cigar-smoke--2 { animation-delay: 0.9s; }

.mlb-icon-box--sm .mlb-cigar-smoke--1 { top: -8rpx;  right: 2rpx; width: 3rpx; height: 10rpx; }
.mlb-icon-box--sm .mlb-cigar-smoke--2 { top: -12rpx; right: 6rpx; width: 2rpx; height: 7rpx; }
.mlb-icon-box--md .mlb-cigar-smoke--1 { top: -12rpx; right: 3rpx; width: 4rpx; height: 15rpx; }
.mlb-icon-box--md .mlb-cigar-smoke--2 { top: -18rpx; right: 8rpx; width: 3rpx; height: 10rpx; }
.mlb-icon-box--lg .mlb-cigar-smoke--1 { top: -16rpx; right: 4rpx; width: 5rpx; height: 20rpx; }
.mlb-icon-box--lg .mlb-cigar-smoke--2 { top: -24rpx; right: 11rpx; width: 4rpx; height: 14rpx; }

@keyframes smokeDrift {
  0%   { opacity: 0;   transform: translateY(0)    scaleX(1); }
  20%  { opacity: 0.7; }
  60%  { opacity: 0.3; }
  100% { opacity: 0;   transform: translateY(-14rpx) scaleX(1.5); }
}

/* 雪茄主体 */
.mlb-cigar-body {
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  background: linear-gradient(90deg,
    #5A4020 0%, #8B6914 20%, #C9A84C 40%,
    #E8C97A 55%, #C9A84C 70%, #8B6914 85%, #5A4020 100%
  );
  box-shadow:
    0 0 8rpx rgba(201,168,76,0.4),
    inset 0 1rpx 1rpx rgba(255,255,255,0.1);
}

.mlb-icon-box--sm .mlb-cigar-body {
  width: 34rpx; height: 11rpx;
  border-radius: 6rpx 2rpx 2rpx 6rpx;
}
.mlb-icon-box--md .mlb-cigar-body {
  width: 48rpx; height: 16rpx;
  border-radius: 8rpx 3rpx 3rpx 8rpx;
}
.mlb-icon-box--lg .mlb-cigar-body {
  width: 64rpx; height: 22rpx;
  border-radius: 11rpx 4rpx 4rpx 11rpx;
}

/* 腰带 */
.mlb-cigar-band {
  position: absolute;
  left: 28%; width: 12%; height: 100%;
  background: rgba(0,0,0,0.3);
  border-left:  1rpx solid rgba(255,255,255,0.1);
  border-right: 1rpx solid rgba(255,255,255,0.06);
}

/* 尖端 + 火星 */
.mlb-cigar-tip {
  position: relative;
  flex-shrink: 0;
  margin-left: -1rpx;
  background: #C9A84C;
  box-shadow: 0 0 6rpx rgba(201,168,76,0.5);
}
.mlb-icon-box--sm .mlb-cigar-tip  { width: 5rpx; height: 8rpx;  border-radius: 0 3rpx 3rpx 0; }
.mlb-icon-box--md .mlb-cigar-tip  { width: 7rpx; height: 11rpx; border-radius: 0 4rpx 4rpx 0; }
.mlb-icon-box--lg .mlb-cigar-tip  { width: 9rpx; height: 15rpx; border-radius: 0 5rpx 5rpx 0; }

.mlb-cigar-ember {
  position: absolute;
  border-radius: 50%;
  background: #FFB84D;
  box-shadow: 0 0 5rpx 2rpx rgba(255,165,50,0.6);
  animation: emberPulse 1.4s ease-in-out infinite;
}
.mlb-icon-box--sm .mlb-cigar-ember  { top: 0rpx; right: -1rpx; width: 3rpx; height: 3rpx; }
.mlb-icon-box--md .mlb-cigar-ember  { top: 1rpx; right: -1rpx; width: 4rpx; height: 4rpx; }
.mlb-icon-box--lg .mlb-cigar-ember  { top: 2rpx; right: -2rpx; width: 5rpx; height: 5rpx; }

@keyframes emberPulse {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50%      { opacity: 1;   transform: scale(1.4); }
}

/* ════════════ 等级数字（两类型共用，保证同一基线） ════════════ */

.mlb-num {
  font-weight: 800;
  color: var(--color-gold-light);
  line-height: 1;
  flex-shrink: 0;
}
.mlb-num--sm { font-size: 22rpx; }
.mlb-num--md { font-size: 30rpx; }
.mlb-num--lg { font-size: 38rpx; }
