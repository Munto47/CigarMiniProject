/* glass-easel 要求根节点始终存在，用空 wrapper 承载 */
.modal-wrap {
  position: fixed;
  z-index: 9999;
  pointer-events: none;
}

/* 遮罩层 */
.modal-mask {
  pointer-events: auto;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.75);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
  animation: maskIn 300ms ease both;
}

/* 弹出卡片（底部抽屉风格） */
.modal-card {
  width: 100%;
  background: #1a1a1a;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  padding: 48rpx 48rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-top: 1rpx solid rgba(201, 168, 76, 0.3);
  animation: slideUp 320ms cubic-bezier(0.34, 1.2, 0.64, 1) both;
}

/* 品牌 logo */
.modal-logo-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
}

.modal-logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
}

.smoke-wrap {
  position: absolute;
  top: -10rpx;
  right: -20rpx;
  display: flex;
  flex-direction: row;
  gap: 5rpx;
}

.smoke {
  width: 5rpx;
  border-radius: 3rpx;
  background: rgba(201, 168, 76, 0.3);
  animation: breathe 2s ease-in-out infinite;
}

.smoke-1 { height: 24rpx; animation-delay: 0s; }
.smoke-2 { height: 36rpx; animation-delay: 0.3s; }
.smoke-3 { height: 18rpx; animation-delay: 0.6s; }

/* 标题区 */
.modal-title-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.modal-eyebrow {
  font-size: 18rpx;
  letter-spacing: 0.3em;
  color: rgba(201, 168, 76, 0.7);
  margin-bottom: 12rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #f5f0e8;
  letter-spacing: 0.05em;
}

/* 权益列表 */
.modal-features {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 48rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.feature-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #c9a84c;
  flex-shrink: 0;
}

.feature-text {
  font-size: 26rpx;
  color: rgba(245, 240, 232, 0.75);
  line-height: 1.5;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #c9a84c 0%, #e8c96d 50%, #c9a84c 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(201, 168, 76, 0.35);
  transition: opacity 200ms;
}

.login-btn text {
  font-size: 30rpx;
  font-weight: 600;
  color: #0d0d0d;
  letter-spacing: 0.05em;
}

.login-btn--loading {
  opacity: 0.7;
}

.login-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid rgba(13, 13, 13, 0.3);
  border-top-color: #0d0d0d;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* 跳过按钮 */
.skip-btn {
  margin-bottom: 24rpx;
}

.skip-btn text {
  font-size: 26rpx;
  color: rgba(245, 240, 232, 0.4);
}

/* 协议提示 */
.modal-tip {
  font-size: 20rpx;
  color: rgba(245, 240, 232, 0.25);
  text-align: center;
  line-height: 1.6;
}

/* 动画 */
@keyframes maskIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

@keyframes breathe {
  0%, 100% { opacity: 0.2; transform: scaleY(0.8); }
  50% { opacity: 0.6; transform: scaleY(1.1); }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
