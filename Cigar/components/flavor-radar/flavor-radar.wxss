.radar-card {
  padding: var(--space-lg);
  margin: var(--space-md) 0;
}

.radar-title {
  display: block;
  margin-bottom: var(--space-lg);
}

.canvas-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-lg);
}

.radar-canvas {
  width: 280px;
  height: 280px;
}

/* 进度条列表 */
.bar-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.bar-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-sm);
}

.bar-label {
  width: 72rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.bar-track {
  flex: 1;
  height: 8rpx;
  background: var(--bg-elevated);
  border-radius: 4rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-gold-dim), var(--color-gold));
  border-radius: 4rpx;
  transition: width 600ms cubic-bezier(0.34, 1.56, 0.64, 1);
  min-width: 4rpx;
}

.bar-value {
  width: 48rpx;
  font-size: 22rpx;
  color: var(--color-gold-dim);
  text-align: right;
  flex-shrink: 0;
}
