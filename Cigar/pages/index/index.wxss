.ai-page {
  height: calc(100vh - 88px);
  background: var(--bg-base);
  padding: 0 var(--space-lg);
  box-sizing: border-box;
}

/* ══ 欢迎页 ══ */
.welcome-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
  animation: fadeIn 600ms ease both;
}

.brand-logo {
  margin-bottom: var(--space-xl);
}

.logo-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
}

.logo-pure {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
}

.smoke-wrap {
  position: absolute;
  top: -20rpx;
  right: -30rpx;
  display: flex;
  flex-direction: row;
  gap: 6rpx;
}

.smoke {
  width: 6rpx;
  border-radius: 3rpx;
  background: rgba(201,168,76,0.25);
  animation: breathe 2s ease-in-out infinite;
}

.smoke-1 { height: 32rpx; animation-delay: 0s; }
.smoke-2 { height: 48rpx; animation-delay: 0.3s; }
.smoke-3 { height: 24rpx; animation-delay: 0.6s; }

.welcome-eyebrow {
  display: block;
  font-size: 20rpx;
  letter-spacing: 0.3em;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 16rpx;
  font-family: var(--font-serif);
}

.welcome-title-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: var(--space-md);
}

.welcome-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  line-height: 1.3;
  font-family: var(--font-serif);
}

.welcome-title--gold {
  color: var(--color-gold);
}

.welcome-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.7;
  margin-bottom: var(--space-xl);
  padding: 0 var(--space-md);
}

.welcome-actions {
  width: 100%;
  margin-bottom: var(--space-lg);
}

.start-btn {
  width: 100%;
  font-size: 34rpx;
  padding: 32rpx;
  box-sizing: border-box;
}

.welcome-divider {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: var(--border-subtle);
}

.divider-text {
  font-size: 22rpx;
  color: var(--text-disabled);
  letter-spacing: 0.05em;
}

/* ══ 问答流 ══ */
.qa-screen {
  padding-top: var(--space-md);
}

.progress-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-lg);
  animation: slideDown 400ms ease both;
}

.progress-track {
  flex: 1;
  height: 4rpx;
  background: var(--bg-elevated);
  border-radius: 2rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-gold-dim), var(--color-gold));
  border-radius: 2rpx;
  transition: width 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.progress-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.card-wrap {
  animation-duration: 350ms;
  animation-fill-mode: both;
  animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
}

.card-enter { animation-name: slideUp; }

.card-exit {
  animation-name: slideLeft;
  animation-timing-function: ease-in;
}

@keyframes slideLeft {
  from { transform: translateX(0);      opacity: 1; }
  to   { transform: translateX(-60rpx); opacity: 0; }
}

/* ══ 加载骨架屏 ══ */
.loading-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  gap: var(--space-lg);
}

.loading-label {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: var(--space-sm);
}

.loading-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  letter-spacing: 0.05em;
}

.loading-dots {
  font-size: 32rpx;
  color: var(--color-gold);
  animation: breathe 1.2s ease-in-out infinite;
}

/* ══ 推荐结果 ══ */
.result-screen {
  padding-top: 80rpx;
}

.result-header {
  text-align: center;
  margin-bottom: var(--space-lg);
  animation: slideDown 400ms ease both;
}

.result-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  font-family: var(--font-serif);
}

.result-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.cigar-card {
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-subtle);
  overflow: hidden;
  margin-bottom: var(--space-md);
  position: relative;
  animation: slideUp 450ms ease both;
}

.cigar-card:nth-child(2) { animation-delay: 80ms; }
.cigar-card:nth-child(3) { animation-delay: 160ms; }

.cigar-card--featured {
  border-color: var(--border-strong);
  box-shadow: var(--shadow-gold);
}

.match-badge {
  position: absolute;
  top: var(--space-sm);
  right: var(--space-sm);
  background: rgba(201,168,76,0.15);
  border: 1rpx solid var(--border-subtle);
  border-radius: var(--radius-full);
  padding: 6rpx 16rpx;
  z-index: 1;
}

.match-text {
  font-size: 20rpx;
  color: var(--color-gold);
  font-weight: 600;
}

.cigar-img-wrap {
  width: 100%;
  height: 200rpx;
  background: var(--bg-elevated);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-cigar {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.placeholder-body {
  width: 360rpx;
  height: 56rpx;
  background: linear-gradient(90deg, #2A2010 0%, #5A4020 40%, #7A6430 60%, #3A2810 100%);
  border-radius: 28rpx 8rpx 8rpx 28rpx;
}

.placeholder-tip {
  width: 20rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #C9A84C, #7A6430);
  border-radius: 0 50% 50% 0;
  margin-left: -2rpx;
}

.cigar-card__info {
  padding: var(--space-md);
}

.cigar-card__header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.cigar-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  flex: 1;
  margin-right: var(--space-sm);
  line-height: 1.3;
  font-family: var(--font-serif);
}

.cigar-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 20rpx;
}

.meta-item {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.meta-sep {
  font-size: 24rpx;
  color: var(--text-disabled);
  margin: 0 10rpx;
}

.tag-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.pairing-row {
  margin-bottom: 20rpx;
}

.pairing-label {
  font-size: 22rpx;
  color: var(--color-gold);
  margin-bottom: 10rpx;
  display: block;
}

.pairing-chips {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
}

.pairing-chip {
  background: rgba(201, 168, 76, 0.12);
  border: 1rpx solid rgba(201, 168, 76, 0.4);
  border-radius: 20rpx;
  padding: 6rpx 18rpx;
  font-size: 22rpx;
  color: var(--color-gold);
}

.cigar-card__actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.cigar-price {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-gold);
  font-family: var(--font-serif);
}

.action-btns {
  display: flex;
  flex-direction: row;
  gap: var(--space-sm);
}

.detail-btn {
  padding: 18rpx 28rpx;
  font-size: 26rpx;
}

.cart-btn {
  padding: 18rpx 28rpx;
  font-size: 26rpx;
}

.restart-wrap {
  margin: var(--space-lg) 0 var(--space-xl);
}

.tab-safe-bottom {
  height: calc(112rpx + env(safe-area-inset-bottom));
}
