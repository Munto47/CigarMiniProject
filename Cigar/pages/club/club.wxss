.club-page {
  height: calc(100vh - 88px);
  background: var(--bg-base);
}

/* ── 会员卡 ── */
.member-card {
  margin: var(--space-md) var(--space-lg);
  padding: var(--space-lg);
  background: linear-gradient(160deg, #100C06 0%, #1E150A 40%, #1A1208 70%, #0F0B05 100%);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border-strong);
  position: relative;
  overflow: hidden;
  box-shadow:
    0 4rpx 32rpx rgba(0,0,0,0.5),
    0 0 60rpx rgba(201,168,76,0.06);
  animation: fadeIn 500ms ease both;
}

.member-card__bg { position: absolute; inset: 0; pointer-events: none; }

.mc-logo-bg {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  width: 200rpx;
  height: 200rpx;
  opacity: 0.05;
  pointer-events: none;
}

.mc-deco {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(201,168,76,0.12);
}
.mc-deco--1 { width: 440rpx; height: 440rpx; top: -220rpx; right: -110rpx; border-color: rgba(201,168,76,0.15); }
.mc-deco--2 { width: 260rpx; height: 260rpx; bottom: -100rpx; left: -50rpx; border-color: rgba(201,168,76,0.08); }
.mc-deco--3 { width: 140rpx; height: 140rpx; top: 80rpx; right: 100rpx; border-color: rgba(201,168,76,0.06); }

.mc-user {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.mc-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, var(--color-gold-dim), var(--color-gold));
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(232,201,122,0.4);
  box-shadow: 0 0 20rpx rgba(201,168,76,0.2);
}

.mc-avatar__init {
  font-size: 40rpx;
  font-weight: 700;
  color: #0D0D0D;
}

.mc-name {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6rpx;
  letter-spacing: 0.04em;
}

.mc-discount {
  font-size: 20rpx;
  color: var(--color-gold);
  letter-spacing: 0.08em;
}

.mc-balance {
  margin-bottom: var(--space-lg);
}

.mc-balance__label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 2rpx;
  letter-spacing: 0.05em;
}

.mc-balance__amount {
  display: block;
  font-size: 60rpx;
  font-weight: 700;
  color: var(--color-gold-light);
  letter-spacing: 0.02em;
  text-shadow: 0 0 30rpx rgba(232,201,122,0.15);
}

/* ════════════ 双等级对称面板 ════════════ */

.mc-level-panels {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-bottom: var(--space-lg);
}

.mc-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding: var(--space-md) var(--space-sm);
  border-radius: var(--radius-md);
  position: relative;
  overflow: hidden;
  box-shadow:
    0 4rpx 20rpx rgba(0,0,0,0.45),
    inset 0 1rpx 0 rgba(201,168,76,0.04);
}

/* 充值面板 — 暖金底 */
.mc-panel--recharge {
  background: linear-gradient(160deg,
    rgba(32,22,8,0.95) 0%,
    rgba(38,26,10,0.9) 50%,
    rgba(28,18,6,0.95) 100%
  );
  border: 1rpx solid rgba(232,201,122,0.28);
}

/* 消费面板 — 棕木底 */
.mc-panel--consume {
  background: linear-gradient(160deg,
    rgba(24,18,10,0.95) 0%,
    rgba(30,22,12,0.9) 50%,
    rgba(22,15,8,0.95) 100%
  );
  border: 1rpx solid rgba(201,168,76,0.18);
}

/* ── 面板内各行的样式（两面板共用，自动对齐） ── */

/* 行1：徽章 — 由 member-level-badge 自行撑高 */
/* 行2：类型标签 */
.mc-panel__label {
  font-size: 22rpx;
  color: var(--text-disabled);
  letter-spacing: 0.1em;
  text-align: center;
  /* 固定行高确保两面板对齐 */
  line-height: 1;
}

/* 行3：进度条 */
.mc-panel__bar {
  width: 100%;
  height: 8rpx;
  background: rgba(201,168,76,0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.mc-panel__bar-fill {
  position: relative;
  height: 100%;
  background: linear-gradient(90deg,
    var(--color-gold-dim) 0%,
    var(--color-gold) 45%,
    var(--color-gold-light) 100%
  );
  border-radius: 4rpx;
  overflow: hidden;
  transition: width 800ms cubic-bezier(0.22, 1, 0.36, 1);
}

.mc-panel__bar-shine {
  position: absolute;
  top: 0;
  left: -40rpx;
  width: 40rpx;
  height: 100%;
  background: linear-gradient(90deg,
    transparent,
    rgba(255,255,255,0.25),
    transparent
  );
  animation: barShine 2.4s ease-in-out infinite;
}

@keyframes barShine {
  0%   { left: -40rpx; }
  100% { left: 100%; }
}

/* 行4：升级提示 */
.mc-panel__hint {
  font-size: 19rpx;
  color: var(--text-disabled);
  text-align: center;
  line-height: 1.4;
}

/* 行5：积分数字 */
.mc-panel__score {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--color-gold-light);
  line-height: 1;
  letter-spacing: 0.02em;
}

.mc-panel__score-unit {
  font-size: 18rpx;
  font-weight: 400;
  color: var(--text-disabled);
  letter-spacing: 0.05em;
}

/* 操作 */
.mc-actions {
  display: flex;
  flex-direction: row;
  gap: var(--space-md);
}

.mc-btn {
  flex: 1;
  padding: 26rpx;
  font-size: 28rpx;
}

/* ── 功能网格 ── */
.function-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: var(--space-md) var(--space-lg);
  gap: 0;
}

.grid-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: var(--space-md) 0;
  box-sizing: border-box;
}

.grid-item:active {
  background: rgba(201,168,76,0.04);
}

.grid-item__icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: var(--bg-elevated);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
}

.grid-item__icon {
  font-size: 36rpx;
  color: var(--color-gold);
}

.grid-item__label {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* ── 活动 Banner ── */
.banner-section {
  padding: var(--space-md) var(--space-lg);
}

.banner-section__title {
  display: block;
  margin-bottom: var(--space-md);
}

.banner-swiper {
  height: 200rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.banner-item {
  height: 200rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-subtle);
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  position: relative;
  overflow: hidden;
}

.banner-content {
  position: relative;
  z-index: 1;
}

.banner-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-gold-light);
  margin-bottom: 8rpx;
}

.banner-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.banner-deco {
  position: absolute;
  right: -40rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 1rpx solid var(--border-subtle);
}

.banner-dots {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 10rpx;
  margin-top: 16rpx;
}

.dot {
  width: 12rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--text-disabled);
  transition: all 300ms ease;
}

.dot--active {
  width: 28rpx;
  background: var(--color-gold);
}

.tab-safe-bottom {
  height: calc(112rpx + env(safe-area-inset-bottom));
}
