.club-page {
  height: calc(100vh - 88px);
  background: var(--bg-base);
}

/* ── 会员卡 ── */
.member-card {
  margin: var(--space-md) var(--space-lg);
  padding: var(--space-lg);
  background: linear-gradient(135deg, #1A1208 0%, #2A1E0A 50%, #1A1208 100%);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border-strong);
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-gold);
  animation: fadeIn 500ms ease both;
}

/* 装饰圆 */
.member-card__bg { position: absolute; inset: 0; pointer-events: none; }

.mc-deco {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(201,168,76,0.12);
}
.mc-deco--1 { width: 400rpx; height: 400rpx; top: -200rpx; right: -100rpx; }
.mc-deco--2 { width: 240rpx; height: 240rpx; bottom: -80rpx; left: -40rpx; border-color: rgba(201,168,76,0.08); }
.mc-deco--3 { width: 120rpx; height: 120rpx; top: 40rpx; right: 80rpx; border-color: rgba(201,168,76,0.06); }

.mc-user {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-lg);
}

.mc-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, var(--color-gold-dim), var(--color-gold));
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(232,201,122,0.4);
}

.mc-avatar__init {
  font-size: 40rpx;
  font-weight: 700;
  color: #0D0D0D;
}

.mc-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.level-badge {
  display: inline-flex;
  background: rgba(201,168,76,0.15);
  border: 1rpx solid var(--border-subtle);
  border-radius: var(--radius-full);
  padding: 4rpx 16rpx;
}

.level-text {
  font-size: 18rpx;
  color: var(--color-gold);
  letter-spacing: 0.15em;
}

.mc-balance {
  margin-bottom: 8rpx;
}

.mc-balance__label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.mc-balance__amount {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-gold-light);
  letter-spacing: 0.02em;
}

.mc-points {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: var(--space-lg);
}

.mc-points__label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.mc-points__val {
  font-size: 24rpx;
  color: var(--color-gold);
  font-weight: 600;
}

.mc-actions {
  display: flex;
  flex-direction: row;
  gap: var(--space-md);
}

.mc-btn {
  flex: 1;
  padding: 24rpx;
  font-size: 28rpx;
}

/* ── 功能网格 ── */
.function-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: var(--space-md) var(--space-lg);
  gap: 0;
}

.grid-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: var(--space-md) 0;
  box-sizing: border-box;
}

.grid-item:active {
  background: rgba(201,168,76,0.04);
}

.grid-item__icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: var(--bg-elevated);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
}

.grid-item__icon {
  font-size: 36rpx;
  color: var(--color-gold);
}

.grid-item__label {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* ── 活动 Banner ── */
.banner-section {
  padding: var(--space-md) var(--space-lg);
}

.banner-section__title {
  display: block;
  margin-bottom: var(--space-md);
}

.banner-swiper {
  height: 200rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.banner-item {
  height: 200rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-subtle);
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  position: relative;
  overflow: hidden;
}

.banner-content {
  position: relative;
  z-index: 1;
}

.banner-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-gold-light);
  margin-bottom: 8rpx;
}

.banner-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.banner-deco {
  position: absolute;
  right: -40rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 1rpx solid var(--border-subtle);
}

.banner-dots {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 10rpx;
  margin-top: 16rpx;
}

.dot {
  width: 12rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--text-disabled);
  transition: all 300ms ease;
}

.dot--active {
  width: 28rpx;
  background: var(--color-gold);
}

.tab-safe-bottom {
  height: calc(112rpx + env(safe-area-inset-bottom));
}
