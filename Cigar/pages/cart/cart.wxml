<navigation-bar
  title="购物车"
  back="{{false}}"
  color="#F5F0E8"
  background="#0D0D0D"
/>

<view class="cart-page">

  <!-- 空购物车 -->
  <view wx:if="{{isEmpty}}" class="cart-empty">
    <view class="empty-illus">
      <view class="empty-bag">
        <view class="empty-bag__handle"></view>
        <view class="empty-bag__body"></view>
      </view>
    </view>
    <text class="empty-title">购物车空空如也</text>
    <text class="empty-desc">去 AI 推荐页发现心仪的雪茄</text>
    <view class="gold-btn empty-cta" bindtap="goExplore">
      <text>去探索</text>
    </view>
  </view>

  <!-- 购物车列表 -->
  <scroll-view wx:else class="cart-list" scroll-y>
    <view
      wx:for="{{items}}"
      wx:key="id"
      class="cart-item"
      style="animation-delay: {{index * 60}}ms"
    >
      <!-- 雪茄图片 -->
      <view class="cart-item__img">
        <view class="cart-mini-cigar">
          <view class="mini-body"></view>
          <view class="mini-tip"></view>
        </view>
      </view>

      <!-- 信息区 -->
      <view class="cart-item__info">
        <text class="cart-item__name">{{item.name}}</text>
        <text class="cart-item__spec">{{item.spec}}</text>
        <view class="cart-item__bottom">
          <text class="cart-item__price">¥ {{item.price}}</text>
          <!-- 数量步进器 -->
          <view class="stepper">
            <view
              class="stepper__btn {{item.qty <= 1 ? 'stepper__btn--disabled' : ''}}"
              bindtap="changeQty"
              data-id="{{item.id}}"
              data-delta="{{-1}}"
            >
              <text class="stepper__sym">−</text>
            </view>
            <text class="stepper__val">{{item.qty}}</text>
            <view class="stepper__btn" bindtap="changeQty" data-id="{{item.id}}" data-delta="{{1}}">
              <text class="stepper__sym">+</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 删除按钮 -->
      <view class="cart-item__del" bindtap="removeItem" data-id="{{item.id}}">
        <text class="del-icon">×</text>
      </view>
    </view>

    <view class="tab-safe-bottom"></view>
  </scroll-view>

  <!-- 底部结算栏 -->
  <view wx:if="{{!isEmpty}}" class="checkout-bar">
    <view class="checkout-bar__inner">
      <view class="total-info">
        <text class="total-label">合计</text>
        <text class="total-amount">¥ {{total}}</text>
      </view>
      <view class="gold-btn checkout-btn" bindtap="checkout">
        <text>去结算（{{items.length}}）</text>
      </view>
    </view>
    <view class="checkout-bar__safe"></view>
  </view>

</view>
