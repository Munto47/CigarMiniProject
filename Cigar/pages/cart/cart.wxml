<navigation-bar
  title="购物车"
  back="{{false}}"
  color="#F5F0E8"
  background="#0D0D0D"
/>

<view class="cart-page">

  <!-- 空购物车 - 未登录 -->
  <view wx:if="{{isEmpty && !isLoggedIn}}" class="cart-empty">
    <view class="empty-illus">
      <view class="empty-bag">
        <view class="empty-bag__handle"></view>
        <view class="empty-bag__body"></view>
      </view>
    </view>
    <text class="empty-title">登录后查看购物车</text>
    <text class="empty-desc">登录即可享受会员专属折扣与积分</text>
    <view class="gold-btn empty-cta" bindtap="doLogin">
      <text>立即登录</text>
    </view>
  </view>

  <!-- 空购物车 - 已登录无商品 -->
  <view wx:if="{{isEmpty && isLoggedIn}}" class="cart-empty-wrap">
    <view class="cart-empty">
      <view class="empty-illus">
        <view class="empty-bag">
          <view class="empty-bag__handle"></view>
          <view class="empty-bag__body"></view>
        </view>
      </view>
      <text class="empty-title">购物车空空如也</text>
      <text class="empty-desc">去 AI 推荐页发现心仪的雪茄</text>
      <view class="gold-btn empty-cta" bindtap="goExplore">
        <text>去探索</text>
      </view>
    </view>
    <view class="tab-safe-bottom"></view>
  </view>

  <!-- 购物车列表 -->
  <scroll-view wx:else class="cart-list" scroll-y>
    <view
      wx:for="{{items}}"
      wx:key="id"
      class="cart-item"
      style="animation-delay: {{index * 60}}ms"
    >

      <!-- 商品图片 -->
      <view
        class="cart-item__img"
        bindtap="onItemImgTap"
        data-item="{{item}}"
      >
        <block wx:if="{{item.productType === 'drink'}}">
          <image
            wx:if="{{item.thumbUrl}}"
            class="cart-drink-img"
            src="{{item.thumbUrl}}"
            mode="aspectFill"
            lazy-load
          />
          <view wx:else class="cart-drink-placeholder">
            <text class="cart-drink-placeholder-icon">🍷</text>
          </view>
        </block>
        <block wx:else>
          <view class="cart-mini-cigar">
            <view class="mini-body"></view>
            <view class="mini-tip"></view>
          </view>
        </block>
      </view>

      <!-- 信息区 -->
      <view
        class="cart-item__info"
        bindtap="goToDetail"
        data-product-id="{{item.productId}}"
        data-product-type="{{item.productType}}"
      >
        <text class="cart-item__name">{{item.name}}</text>
        <text class="cart-item__spec">{{item.spec}}</text>
        <view class="cart-item__bottom">
          <text class="cart-item__price">¥ {{item.price}}</text>
          <!-- 数量步进器 -->
          <view class="stepper">
            <view
              class="stepper__btn {{item.qty <= 1 ? 'stepper__btn--disabled' : ''}}"
              bindtap="changeQty"
              data-id="{{item.id}}"
              data-delta="{{-1}}"
            >
              <text class="stepper__sym">−</text>
            </view>
            <text class="stepper__val">{{item.qty}}</text>
            <view class="stepper__btn" bindtap="changeQty" data-id="{{item.id}}" data-delta="{{1}}">
              <text class="stepper__sym">+</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 删除按钮 -->
      <view class="cart-item__del" bindtap="removeItem" data-id="{{item.id}}">
        <text class="del-icon">×</text>
      </view>
    </view>

    <view class="tab-safe-bottom"></view>
  </scroll-view>

  <!-- 底部结算栏 -->
  <view wx:if="{{!isEmpty}}" class="checkout-bar">
    <view class="checkout-bar__inner">
      <view class="total-info">
        <text class="total-label">合计</text>
        <text class="total-amount">¥ {{total}}</text>
      </view>
      <view class="gold-btn checkout-btn" bindtap="checkout">
        <text>去结算（{{items.length}}）</text>
      </view>
    </view>
    <view class="checkout-bar__safe"></view>
  </view>

</view>

<!-- ══ 饮品详情弹窗 ══ -->
<view wx:if="{{showDrinkModal && activeDrink}}" class="drink-mask" bindtap="closeDrinkModal">
  <view class="drink-panel" catchtap>
    <view class="drink-panel__handle"></view>

    <view class="drink-panel__img-wrap">
      <image
        wx:if="{{activeDrink.thumbUrl}}"
        class="drink-panel__img"
        src="{{activeDrink.thumbUrl}}"
        mode="aspectFill"
      />
      <view wx:else class="drink-panel__img-placeholder">
        <text class="drink-panel__placeholder-icon">🍷</text>
      </view>
    </view>

    <view class="drink-panel__info">
      <text class="drink-panel__name">{{activeDrink.name}}</text>
      <text wx:if="{{activeDrink.categoryName || activeDrink.categoryCode}}" class="drink-panel__category">{{activeDrink.categoryName || activeDrink.categoryCode}}</text>
      <view class="drink-panel__price-row">
        <text class="drink-panel__price">¥ {{activeDrink.price}}</text>
        <text wx:if="{{activeDrink.stockAvailable <= 0}}" class="drink-panel__stock-out">已售罄</text>
      </view>
      <text wx:if="{{activeDrink.description}}" class="drink-panel__desc">{{activeDrink.description}}</text>
    </view>

    <view class="drink-panel__actions">
      <view class="ghost-btn drink-panel__cart-btn" bindtap="addDrinkToCart" data-drink="{{activeDrink}}">
        <text>加入购物车</text>
      </view>
      <view class="gold-btn drink-panel__order-btn" bindtap="orderDrinkNow" data-drink="{{activeDrink}}">
        <text>立即下单</text>
      </view>
    </view>
  </view>
</view>
