.cart-page {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 88px);
  background: var(--bg-base);
}

/* 空态 */
.cart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: var(--space-xl);
  gap: var(--space-md);
}

.empty-illus {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-md);
}

.empty-bag {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

.empty-bag__handle {
  width: 60rpx;
  height: 28rpx;
  border: 3rpx solid var(--border-subtle);
  border-bottom: none;
  border-radius: 16rpx 16rpx 0 0;
}

.empty-bag__body {
  width: 100rpx;
  height: 80rpx;
  border: 3rpx solid var(--border-subtle);
  border-radius: 8rpx 8rpx var(--radius-sm) var(--radius-sm);
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
}

.empty-cta {
  padding: 24rpx 64rpx;
  margin-top: var(--space-sm);
}

/* 购物车列表 */
.cart-list {
  flex: 1;
}

.cart-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
  border-bottom: 1rpx solid var(--border-subtle);
  animation: slideUp 300ms ease both;
}

.cart-item__img {
  width: 100rpx;
  height: 100rpx;
  background: var(--bg-elevated);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: var(--space-md);
}

.cart-drink-img {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-sm);
}

.cart-mini-cigar {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.mini-body {
  width: 64rpx;
  height: 18rpx;
  background: linear-gradient(90deg, #5A4020, #C9A84C, #7A6430);
  border-radius: 9rpx 3rpx 3rpx 9rpx;
}

.mini-tip {
  width: 8rpx;
  height: 10rpx;
  background: #C9A84C;
  border-radius: 0 4rpx 4rpx 0;
  margin-left: -1rpx;
}

.cart-item__info {
  flex: 1;
}

.cart-item__name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 6rpx;
}

.cart-item__spec {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.cart-item__bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.cart-item__price {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-gold);
}

/* 步进器 */
.stepper {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 0;
  border: 1rpx solid var(--border-subtle);
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.stepper__btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-elevated);
}

.stepper__btn:active {
  background: rgba(201,168,76,0.1);
}

.stepper__btn--disabled {
  opacity: 0.3;
}

.stepper__sym {
  font-size: 28rpx;
  color: var(--color-gold);
  line-height: 1;
}

.stepper__val {
  min-width: 52rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
  padding: 0 8rpx;
}

/* 删除按钮 */
.cart-item__del {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: var(--space-sm);
}

.del-icon {
  font-size: 36rpx;
  color: var(--text-disabled);
}

.cart-item__del:active .del-icon {
  color: var(--color-danger);
}

/* 结算栏 */
.checkout-bar {
  background: var(--bg-surface);
  border-top: 1rpx solid var(--border-subtle);
}

.checkout-bar__inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) var(--space-lg);
  gap: var(--space-md);
}

.checkout-bar__safe {
  height: env(safe-area-inset-bottom);
}

.total-info {
  display: flex;
  flex-direction: column;
}

.total-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.total-amount {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-gold);
}

.checkout-btn {
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  flex-shrink: 0;
}

.tab-safe-bottom {
  height: calc(112rpx + env(safe-area-inset-bottom));
}

/* 空购物车已登录包装容器（含海报历史） */
.cart-empty-wrap {
  display: flex;
  flex-direction: column;
  flex: 1;
  overflow-y: auto;
}

/* ── 饮品图片占位符 ── */
.cart-drink-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1A1208, #0F0C06);
  border-radius: var(--radius-sm);
}

.cart-drink-placeholder-icon {
  font-size: 44rpx;
}

/* ══ 饮品详情弹窗 ══ */
.drink-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.72);
  display: flex;
  align-items: flex-end;
  z-index: 1100;
  animation: maskIn 250ms ease both;
}

@keyframes maskIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.drink-panel {
  width: 100%;
  background: linear-gradient(180deg, #1A1208 0%, #100C06 100%);
  border-top: 1rpx solid rgba(201, 168, 76, 0.35);
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: calc(var(--space-xl) + env(safe-area-inset-bottom));
  animation: panelUp 300ms cubic-bezier(0.22, 1, 0.36, 1) both;
  overflow: hidden;
}

@keyframes panelUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

.drink-panel__handle {
  width: 64rpx;
  height: 6rpx;
  background: rgba(201, 168, 76, 0.3);
  border-radius: 3rpx;
  margin: 20rpx auto 0;
}

.drink-panel__img-wrap {
  width: 100%;
  height: 320rpx;
  margin-top: 24rpx;
  overflow: hidden;
  background: var(--bg-surface);
}

.drink-panel__img {
  width: 100%;
  height: 100%;
}

.drink-panel__img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1A1208, #0F0C06);
}

.drink-panel__placeholder-icon {
  font-size: 96rpx;
}

.drink-panel__info {
  padding: var(--space-lg) var(--space-lg) 0;
}

.drink-panel__name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  font-family: var(--font-serif);
}

.drink-panel__category {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.08em;
  margin-bottom: 16rpx;
}

.drink-panel__price-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.drink-panel__price {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--color-gold);
  font-family: var(--font-serif);
}

.drink-panel__stock-out {
  font-size: 22rpx;
  color: var(--text-disabled);
  background: var(--bg-elevated);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.drink-panel__desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.drink-panel__actions {
  display: flex;
  flex-direction: row;
  gap: var(--space-md);
  padding: var(--space-lg) var(--space-lg) 0;
}

.drink-panel__cart-btn {
  flex: 1;
  padding: 26rpx;
  font-size: 28rpx;
}

.drink-panel__order-btn {
  flex: 1;
  padding: 26rpx;
  font-size: 28rpx;
  font-weight: 700;
}

