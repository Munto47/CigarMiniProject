.detail-page {
  height: 100vh;
  background: var(--bg-base);
}

/* 右上角关闭按钮（navigation-bar right slot） */
.nav-close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(13, 13, 13, 0.55);
  border: 1rpx solid rgba(201, 168, 76, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
}

.nav-close-icon {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1;
}

/* 滚动区底部留白：让最后内容能滚出 tab-bar 遮挡区域 */
.page-bottom-safe {
  height: calc(var(--tab-bar-height) + 40rpx);
}

/* Hero */
.hero-section {
  height: 480rpx;
  position: relative;
  background: linear-gradient(180deg, #0D0D0D 0%, #1A1208 100%);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-img {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 100ms linear;
}

.hero-cigar-art {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.hero-cigar-body {
  width: 500rpx;
  height: 80rpx;
  background: linear-gradient(90deg, #5A3010 0%, #C9A84C 35%, #E8C97A 50%, #C9A84C 65%, #5A3010 100%);
  border-radius: 40rpx 8rpx 8rpx 40rpx;
  position: relative;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 40rpx rgba(201,168,76,0.2);
}

.hero-cigar-band {
  position: absolute;
  left: 150rpx;
  width: 60rpx;
  height: 100%;
  background: rgba(0,0,0,0.3);
  border-left: 1rpx solid rgba(232,201,122,0.5);
  border-right: 1rpx solid rgba(232,201,122,0.5);
}

.hero-cigar-tip {
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #E8C97A, #C9A84C);
  border-radius: 50%;
  margin-left: -4rpx;
}

.hero-smoke {
  position: absolute;
  top: 60rpx;
  right: 80rpx;
  display: flex;
  flex-direction: row;
  gap: 8rpx;
}

.smoke {
  border-radius: 4rpx;
  background: rgba(201,168,76,0.15);
  animation: breathe 2s ease-in-out infinite;
}

.smoke-1 { width: 8rpx; height: 48rpx; animation-delay: 0s; }
.smoke-2 { width: 8rpx; height: 72rpx; animation-delay: 0.4s; }
.smoke-3 { width: 8rpx; height: 36rpx; animation-delay: 0.8s; }

.hero-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(transparent, var(--bg-base));
}

/* 基础信息 */
.info-section {
  padding: var(--space-md) var(--space-lg);
  animation: slideUp 400ms ease both;
}

.info-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
}

.cigar-name {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.3;
  margin-bottom: 10rpx;
  font-family: var(--font-serif);
}

.cigar-meta-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.meta-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.meta-sep {
  font-size: 24rpx;
  color: var(--text-disabled);
  margin: 0 10rpx;
}

.rating-lg {
  padding: 12rpx 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.tag-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: var(--space-md);
}

.buy-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-md);
}

.price-big {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-gold);
  font-family: var(--font-serif);
}

.buy-btn {
  padding: 24rpx 48rpx;
  font-size: 30rpx;
}

.duration-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.duration-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  border: 2rpx solid var(--text-secondary);
  position: relative;
}

.duration-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 区块 */
.section-wrap {
  padding: var(--space-lg) var(--space-lg) var(--space-md);
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-gold);
  letter-spacing: 0.05em;
  margin-bottom: var(--space-md);
  font-family: var(--font-serif);
}

/* 分段描述 */
.segment-item {
  display: flex;
  flex-direction: row;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.segment-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: var(--color-gold);
  flex-shrink: 0;
  margin-top: 10rpx;
}

.segment-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-gold-light);
  margin-bottom: 8rpx;
}

.segment-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* ══ 配饮推荐卡片 ══ */
.pairing-scroll {
  margin: 0 calc(-1 * var(--space-lg));
  padding: 0 var(--space-lg);
}

.pairing-list {
  display: flex;
  flex-direction: row;
  gap: var(--space-md);
  padding-right: var(--space-lg);
}

.pairing-card {
  display: flex;
  flex-direction: column;
  width: 260rpx;
  flex-shrink: 0;
  background: var(--bg-elevated);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-subtle);
  overflow: hidden;
}

/* 图片区 */
.pairing-img-wrap {
  width: 100%;
  height: 180rpx;
  background: var(--bg-surface);
  position: relative;
  overflow: hidden;
}

.pairing-img {
  width: 100%;
  height: 100%;
}

.pairing-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1A1208, #0F0C06);
}

.pairing-placeholder-icon {
  font-size: 56rpx;
}

/* 信息区 */
.pairing-info {
  padding: 16rpx 18rpx 12rpx;
  flex: 1;
}

.pairing-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
  line-height: 1.3;
}

.pairing-price {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-gold);
  margin-bottom: 8rpx;
}

.pairing-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 操作区 */
.pairing-actions {
  display: flex;
  flex-direction: row;
  border-top: 1rpx solid var(--border-subtle);
}

.pairing-cart-btn,
.pairing-order-btn {
  flex: 1;
  padding: 18rpx 0;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
}

.pairing-cart-btn {
  color: var(--text-secondary);
  border-right: 1rpx solid var(--border-subtle);
}

.pairing-cart-btn:active {
  background: rgba(201, 168, 76, 0.06);
}

.pairing-order-btn {
  color: var(--color-gold);
}

.pairing-order-btn:active {
  background: rgba(201, 168, 76, 0.08);
}

/* ══ 配饮详情弹窗 ══ */
.drink-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.72);
  display: flex;
  align-items: flex-end;
  z-index: 1100;
  animation: maskIn 250ms ease both;
}

.drink-panel {
  width: 100%;
  background: linear-gradient(180deg, #1A1208 0%, #100C06 100%);
  border-top: 1rpx solid rgba(201, 168, 76, 0.35);
  border-radius: 32rpx 32rpx 0 0;
  /* 112rpx = tab-bar 高度，保证内容不被遮挡 */
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
  animation: panelUp 300ms cubic-bezier(0.22, 1, 0.36, 1) both;
  overflow: hidden;
}

.drink-panel__handle {
  width: 64rpx;
  height: 6rpx;
  background: rgba(201, 168, 76, 0.3);
  border-radius: 3rpx;
  margin: 20rpx auto 0;
}

.drink-panel__img-wrap {
  width: 100%;
  height: 360rpx;
  margin-top: 24rpx;
  overflow: hidden;
  background: var(--bg-surface);
}

.drink-panel__img {
  width: 100%;
  height: 100%;
}

.drink-panel__img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1A1208, #0F0C06);
}

.drink-panel__placeholder-icon {
  font-size: 96rpx;
}

.drink-panel__info {
  padding: var(--space-lg) var(--space-lg) 0;
}

.drink-panel__name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  font-family: var(--font-serif);
}

.drink-panel__category {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.08em;
  margin-bottom: 16rpx;
}

.drink-panel__price-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.drink-panel__price {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--color-gold);
  font-family: var(--font-serif);
}

.drink-panel__stock-out {
  font-size: 22rpx;
  color: var(--text-disabled);
  background: var(--bg-elevated);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.drink-panel__desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.drink-panel__actions {
  display: flex;
  flex-direction: row;
  gap: var(--space-md);
  padding: var(--space-lg) var(--space-lg) 0;
}

.drink-panel__cart-btn {
  flex: 1;
  padding: 26rpx;
  font-size: 28rpx;
}

.drink-panel__order-btn {
  flex: 1;
  padding: 26rpx;
  font-size: 28rpx;
  font-weight: 700;
}

/* 相关推荐 */
.related-scroll {
  white-space: nowrap;
  margin: 0 calc(-1 * var(--space-lg));
  padding: 0 var(--space-lg);
}

.related-list {
  display: flex;
  flex-direction: row;
  gap: var(--space-md);
  padding-right: var(--space-lg);
}

.related-card {
  display: flex;
  flex-direction: column;
  width: 280rpx;
  flex-shrink: 0;
  background: var(--bg-elevated);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-subtle);
  padding: var(--space-md);
}

.related-card:active {
  transform: scale(0.97);
}

.related-img {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: var(--space-sm);
  height: 48rpx;
}

.r-mini-body {
  width: 180rpx;
  height: 32rpx;
  background: linear-gradient(90deg, #5A4020, #C9A84C);
  border-radius: 16rpx 4rpx 4rpx 16rpx;
}

.r-mini-tip {
  width: 10rpx;
  height: 18rpx;
  background: #C9A84C;
  border-radius: 0 5rpx 5rpx 0;
  margin-left: -1rpx;
}

.related-name {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
  margin-bottom: var(--space-sm);
  white-space: normal;
}

.related-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.related-price {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-gold);
}

/* ════════════════════════════════════════
   Ambient Effects — 全屏漂浮火星 Embers
   fixed 定位，覆盖整个视口，pointer-events:none 不遮挡操作
   ════════════════════════════════════════ */
.ambient-effects {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 6;
  overflow: hidden;
}

/* 上浮轨迹：覆盖全屏高度，略带左右漂移 */
@keyframes emberRise {
  0%   { transform: translateY(0);                   opacity: 0; }
  8%   { opacity: 0.9; }
  88%  { opacity: 0.6; }
  100% { transform: translateY(-105vh);               opacity: 0; }
}
@keyframes emberRiseL {
  0%   { transform: translate(0, 0);                  opacity: 0; }
  8%   { opacity: 0.9; }
  100% { transform: translate(-18px, -105vh);          opacity: 0; }
}
@keyframes emberRiseR {
  0%   { transform: translate(0, 0);                  opacity: 0; }
  8%   { opacity: 0.9; }
  100% { transform: translate(16px, -105vh);           opacity: 0; }
}
@keyframes emberRiseLL {
  0%   { transform: translate(0, 0);                  opacity: 0; }
  8%   { opacity: 0.85; }
  100% { transform: translate(-28px, -105vh);          opacity: 0; }
}
@keyframes emberRiseRR {
  0%   { transform: translate(0, 0);                  opacity: 0; }
  8%   { opacity: 0.85; }
  100% { transform: translate(24px, -105vh);           opacity: 0; }
}

/* 基础粒子 */
.ember {
  position: absolute;
  border-radius: 50%;
  background: #E8C97A;
  box-shadow: 0 0 8rpx 2rpx rgba(232, 201, 122, 0.6);
  bottom: 0;
}

/*
  负延迟让粒子在动画周期中途"入场"，
  使它们在页面不同高度同时可见，而不是全从底部一起出发。
  left 值覆盖屏幕全宽，避免集中在雪茄图位置。
*/
.e1  { left:  8%; width: 5rpx;  height: 5rpx;  animation: emberRiseL  4.2s ease-in infinite -1.0s; }
.e2  { left: 20%; width: 4rpx;  height: 4rpx;  animation: emberRise   3.5s ease-in infinite -2.8s; }
.e3  { left: 33%; width: 6rpx;  height: 6rpx;  animation: emberRiseR  4.8s ease-in infinite -0.5s; }
.e4  { left: 47%; width: 4rpx;  height: 4rpx;  animation: emberRiseLL 3.8s ease-in infinite -3.4s; }
.e5  { left: 58%; width: 8rpx;  height: 8rpx;  animation: emberRise   5.0s ease-in infinite -1.9s; box-shadow: 0 0 12rpx 3rpx rgba(232,201,122,0.75); }
.e6  { left: 68%; width: 5rpx;  height: 5rpx;  animation: emberRiseRR 4.0s ease-in infinite -0.8s; }
.e7  { left: 78%; width: 4rpx;  height: 4rpx;  animation: emberRiseL  3.3s ease-in infinite -4.0s; }
.e8  { left: 87%; width: 6rpx;  height: 6rpx;  animation: emberRiseR  4.5s ease-in infinite -2.2s; }
.e9  { left: 42%; width: 4rpx;  height: 4rpx;  animation: emberRise   3.6s ease-in infinite -3.8s; }
.e10 { left: 14%; width: 7rpx;  height: 7rpx;  animation: emberRiseRR 5.2s ease-in infinite -1.5s; box-shadow: 0 0 10rpx 3rpx rgba(232,201,122,0.7); }

/* ════════════════════════════════════════
   品鉴评价区
   ════════════════════════════════════════ */
.review-header {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: var(--space-lg);
}

.review-header__left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.review-total {
  font-size: 22rpx;
  color: var(--text-disabled);
  letter-spacing: 0.03em;
}

.review-header__avg {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.review-avg-score {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-gold);
  line-height: 1;
  font-family: var(--font-serif);
}

/* 单条评论 */
.review-item {
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--border-subtle);
}

.review-item:last-of-type {
  border-bottom: none;
  margin-bottom: var(--space-md);
}

.review-item__header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.review-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, var(--color-gold-dim), var(--color-gold));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.review-avatar__text {
  font-size: 26rpx;
  font-weight: 700;
  color: #0D0D0D;
}

.review-item__identity {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

/* 身份条：VIP徽章 + 昵称 + 雪茄徽章 — 行内展平 */
.review-item__id-strip {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.review-item__meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.review-item__name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.review-item__time {
  font-size: 22rpx;
  color: var(--text-disabled);
  flex-shrink: 0;
}

.review-item__content {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.write-review-btn {
  margin-top: var(--space-lg);
  width: 100%;
  box-sizing: border-box;
}

/* ════════════════════════════════════════
   评价输入 Modal（从底部滑入）
   ════════════════════════════════════════ */
.review-modal-mask {
  position: fixed;
  inset: 0;
  background: var(--bg-overlay);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  animation: fadeIn 200ms ease both;
}

.review-modal {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  border-top: 1rpx solid var(--border-subtle);
  padding: var(--space-md) var(--space-lg) 0;
  /* 弹窗已盖过 tab-bar，底部只需要设备安全区即可 */
  padding-bottom: calc(var(--space-lg) + env(safe-area-inset-bottom));
  animation: slideUp 280ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.review-modal__handle {
  width: 80rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: rgba(201, 168, 76, 0.25);
  margin: 0 auto var(--space-md);
}

.review-modal__title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  font-family: var(--font-serif);
  margin-bottom: var(--space-lg);
  text-align: center;
}

.review-modal__rating-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-lg);
  background: var(--bg-surface);
  border: 1rpx solid var(--border-subtle);
  border-radius: var(--radius-md);
  padding: var(--space-md);
}

.review-modal__rating-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.review-modal__input {
  width: 100%;
  min-height: 200rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-subtle);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  box-sizing: border-box;
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.review-modal__count {
  display: block;
  font-size: 22rpx;
  color: var(--text-disabled);
  text-align: right;
  margin-bottom: var(--space-lg);
}

.review-modal__submit {
  width: 100%;
  box-sizing: border-box;
  margin-bottom: var(--space-sm);
}

.review-modal__cancel {
  width: 100%;
  box-sizing: border-box;
}
