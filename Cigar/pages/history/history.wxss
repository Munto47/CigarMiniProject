.history-page {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 88px);
  background: var(--bg-base);
}

/* 筛选栏 */
.filter-bar {
  flex-shrink: 0;
  white-space: nowrap;
  border-bottom: 1rpx solid var(--border-subtle);
}

.filter-inner {
  display: flex;
  flex-direction: row;
  padding: 0 var(--space-lg);
  gap: 0;
}

.filter-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  position: relative;
}

.filter-tab__text {
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: color 200ms ease;
}

.filter-tab--active .filter-tab__text {
  color: var(--color-gold);
  font-weight: 600;
}

.filter-tab--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 32rpx;
  right: 32rpx;
  height: 3rpx;
  background: var(--color-gold);
  border-radius: 2rpx;
}

/* 历史列表 */
.history-list {
  flex: 1;
  height: 0;
  overflow-y: auto;
}

.history-group {
  margin-bottom: var(--space-md);
}

.group-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--space-md) var(--space-lg) var(--space-sm);
  gap: var(--space-md);
}

.group-date {
  font-size: 22rpx;
  color: var(--text-disabled);
  letter-spacing: 0.05em;
  flex-shrink: 0;
}

.group-divider {
  flex: 1;
  height: 1rpx;
  background: var(--border-subtle);
}

/* 历史条目 */
.history-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: var(--space-md) var(--space-lg);
  gap: var(--space-md);
  border-bottom: 1rpx solid rgba(201,168,76,0.06);
}

.history-item:active {
  background: rgba(201,168,76,0.04);
}

.h-item__img {
  width: 88rpx;
  height: 88rpx;
  background: var(--bg-elevated);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.h-mini-cigar {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.h-mini-body {
  width: 56rpx;
  height: 16rpx;
  background: linear-gradient(90deg, #5A4020, #C9A84C);
  border-radius: 8rpx 2rpx 2rpx 8rpx;
}

.h-mini-tip {
  width: 7rpx;
  height: 9rpx;
  background: #C9A84C;
  border-radius: 0 3rpx 3rpx 0;
  margin-left: -1rpx;
}

.h-item__info {
  flex: 1;
  min-width: 0;
}

.h-item__header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.h-item__name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.h-item__time {
  font-size: 20rpx;
  color: var(--text-disabled);
  flex-shrink: 0;
  margin-left: var(--space-sm);
  margin-right: var(--space-xs);
}

.h-item__origin {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.h-item__tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
}

.type-chip {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  background: rgba(201,168,76,0.1);
}

.type-chip--purchased { background: rgba(76,175,122,0.1); }
.type-chip--poster    { background: rgba(201,168,76,0.15); }

.type-chip__text {
  font-size: 18rpx;
  color: var(--color-gold);
  font-weight: 600;
}

.type-chip--purchased .type-chip__text { color: var(--color-success); }

/* 操作按钮 */
.h-item__actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
}

.h-action-btn {
  padding: 10rpx 20rpx;
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border-subtle);
  background: var(--bg-elevated);
  display: flex;
  align-items: center;
  justify-content: center;
}

.h-action-btn--gold {
  border-color: var(--border-strong);
  background: rgba(201,168,76,0.08);
}

.h-action-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.h-action-text--gold {
  color: var(--color-gold);
}

.tab-safe-bottom {
  height: calc(112rpx + env(safe-area-inset-bottom));
}
