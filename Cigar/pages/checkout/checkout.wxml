<navigation-bar
  title="确认订单"
  back="{{true}}"
  color="#F5F0E8"
  background="#0D0D0D"
/>

<view class="checkout-page">
  <scroll-view class="checkout-content" scroll-y>

    <!-- ── 订单明细 ── -->
    <view class="order-section">
      <text class="order-section__title">订单明细</text>
      <view
        wx:for="{{order.items}}"
        wx:key="id"
        class="order-item"
      >
        <view class="order-item__img">
          <view class="o-mini-body"></view>
          <view class="o-mini-tip"></view>
        </view>
        <view class="order-item__info">
          <text class="order-item__name">{{item.name}}</text>
          <text class="order-item__spec">{{item.spec}} × {{item.qty}}</text>
        </view>
        <text class="order-item__subtotal">¥ {{item.price * item.qty}}</text>
      </view>
    </view>

    <view class="divider"></view>

    <!-- ── 金额汇总 ── -->
    <view class="amount-section">
      <view class="amount-row">
        <text class="amount-label">商品合计</text>
        <text class="amount-value">¥ {{subtotal}}</text>
      </view>
      <view class="amount-row">
        <text class="amount-label">会员折扣</text>
        <text class="amount-value amount-value--gold">{{order.discount}}</text>
      </view>
      <view class="amount-divider"></view>
      <view class="amount-row">
        <text class="amount-label amount-label--lg">实付金额</text>
        <text class="amount-value amount-value--total">¥ {{total}}</text>
      </view>
    </view>

    <view class="divider"></view>

    <!-- ── 支付方式 ── -->
    <view class="pay-section">
      <text class="pay-section__title">支付方式</text>

      <!-- 选项 A: 余额支付 -->
      <view
        class="pay-option {{payMethod === 'balance' ? 'pay-option--selected' : ''}}"
        bindtap="selectPayMethod"
        data-method="balance"
      >
        <view class="pay-option__icon pay-icon-wallet">
          <view class="wallet-shape"></view>
        </view>
        <view class="pay-option__info">
          <text class="pay-option__name">会员储值余额</text>
          <text class="pay-option__sub">当前余额 ¥ {{order.memberBalance}}</text>
        </view>
        <view class="pay-radio {{payMethod === 'balance' ? 'pay-radio--active' : ''}}">
          <view wx:if="{{payMethod === 'balance'}}" class="pay-radio__dot"></view>
        </view>
      </view>

      <!-- 选项 B: 美团收银 -->
      <view
        class="pay-option {{payMethod === 'meituan' ? 'pay-option--selected' : ''}}"
        bindtap="selectPayMethod"
        data-method="meituan"
      >
        <view class="pay-option__icon pay-icon-meituan">
          <view class="meituan-shape"></view>
        </view>
        <view class="pay-option__info">
          <text class="pay-option__name">美团收银</text>
          <text class="pay-option__sub">跳转美团收银台支付</text>
        </view>
        <view class="pay-radio {{payMethod === 'meituan' ? 'pay-radio--active' : ''}}">
          <view wx:if="{{payMethod === 'meituan'}}" class="pay-radio__dot"></view>
        </view>
      </view>
    </view>

  </scroll-view>

  <!-- ── 固定底部支付按钮 ── -->
  <view class="pay-footer">
    <view class="pay-footer__inner">
      <view class="pay-total-info">
        <text class="pay-total-label">实付</text>
        <text class="pay-total-amount">¥ {{total}}</text>
      </view>
      <view
        class="gold-btn pay-confirm-btn {{paying ? 'pay-confirm-btn--loading' : ''}}"
        bindtap="pay"
      >
        <text>{{paying ? '处理中...' : '确认支付'}}</text>
      </view>
    </view>
    <view class="pay-footer__safe"></view>
  </view>
</view>

<!-- ══ 订单完成 · 评价弹窗 ══ -->
<view wx:if="{{showRateModal}}" class="rate-modal-mask" bindtap="closeRateModal">
  <view class="rate-modal" catchtap>

    <!-- 拖拽条 -->
    <view class="rate-modal__handle"></view>
    <text class="rate-modal__title">为本次品鉴打分</text>
    <text class="rate-modal__subtitle">您的评价将帮助更多爱好者做出选择</text>

    <!-- 商品缩略图 -->
    <view class="rate-modal__items">
      <view wx:for="{{order.items}}" wx:key="id" class="rate-modal__item">
        <view class="rate-modal__item-img">
          <view class="rm-mini-body"></view>
          <view class="rm-mini-tip"></view>
        </view>
        <view class="rate-modal__item-info">
          <text class="rate-modal__item-name">{{item.name}}</text>
          <text class="rate-modal__item-spec">{{item.spec}}</text>
        </view>
      </view>
    </view>

    <!-- 雪茄评分控件 -->
    <view class="rate-modal__rating-wrap">
      <cigar-rating
        value="{{rateScore}}"
        readonly="{{false}}"
        size="lg"
        bindchange="onRateScoreChange"
      />
      <text class="rate-modal__rating-hint">
        {{rateScore === 0 ? '点击打分' : rateScore === 5 ? '完美！' : rateScore >= 4 ? '很满意' : rateScore >= 3 ? '还不错' : '一般般'}}
      </text>
    </view>

    <!-- 文字输入 -->
    <textarea
      class="rate-modal__input"
      placeholder="分享您的品鉴感受（选填）"
      placeholder-style="color: #4A4540; font-size: 28rpx;"
      value="{{rateText}}"
      bindinput="onRateTextInput"
      maxlength="200"
      auto-height
    />

    <!-- 操作按钮 -->
    <view
      class="gold-btn rate-modal__submit {{rateScore === 0 ? 'rate-modal__submit--disabled' : ''}}"
      bindtap="submitRate"
    >
      <text>提交评价</text>
    </view>
    <view class="ghost-btn rate-modal__skip" bindtap="closeRateModal">
      <text>暂不评价</text>
    </view>

  </view>
</view>

<custom-tab-bar />
