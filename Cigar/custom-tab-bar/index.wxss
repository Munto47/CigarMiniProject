/* ── 标签文字 ── */
.tab-label {
  font-size: 20rpx;
  color: #4A4540;
  letter-spacing: 0.03em;
  transition: color 200ms ease;
}

.tab-item--active .tab-label {
  color: #C9A84C;
  font-weight: 600;
}

/* ── 选中指示点 ── */
.tab-dot {
  position: absolute;
  bottom: 6rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #C9A84C;
  animation: fadeIn 200ms ease;
}

/* ── 购物车角标 ── */
.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #C94C4C;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  border: 2rpx solid #161616;
}

.cart-badge__text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}
