.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #161616;
  z-index: 999;
}

.tab-bar__border {
  height: 1rpx;
  background: rgba(201, 168, 76, 0.15);
}

.tab-bar__inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  height: 112rpx;
  padding: 0 8rpx;
}

.tab-bar__safe-area {
  height: env(safe-area-inset-bottom);
}

/* ── Tab 单项 ── */
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  position: relative;
  padding-top: 8rpx;
}

/* ── 图标基础 ── */
.tab-icon {
  width: 48rpx;
  height: 48rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  position: relative;
  margin-bottom: 6rpx;
  transition: transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-item--active .tab-icon {
  transform: scale(1.15);
}

